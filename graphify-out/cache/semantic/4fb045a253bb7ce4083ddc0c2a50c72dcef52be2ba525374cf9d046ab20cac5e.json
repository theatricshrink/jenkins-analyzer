{"nodes": [{"id": "specs_llm_context_enrichment_design", "label": "LLM Context Enrichment Design Spec", "file_type": "document", "source_file": "docs/superpowers/specs/2026-05-31-llm-context-enrichment-design.md", "source_location": "1", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "specs_natural_language_query", "label": "Natural Language Query over SQLite Analytics", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-05-31-llm-context-enrichment-design.md", "source_location": "1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "POST /query endpoint uses LLM to translate natural-language questions to read-only SELECT SQL, enforcing safety via regex guard. QUERY_SYSTEM_PROMPT provides table schema and rules to LLM."}, {"id": "specs_background_cleanup", "label": "Background DB Cleanup Task", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-05-31-llm-context-enrichment-design.md", "source_location": "63-69", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "asyncio task started in lifespan runs every 24h deleting rows older than RETENTION_DAYS (default 365). Sleep-first pattern means first cleanup is 24h after startup."}, {"id": "specs_tail_lines_trimming", "label": "tail_lines Log Trimming", "file_type": "concept", "source_file": "docs/superpowers/specs/2026-05-31-llm-context-enrichment-design.md", "source_location": "37-51", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Optional per-request parameter to send only the last N lines to LLM, reducing token cost for large logs while preserving the error-dense tail section."}], "edges": [{"source": "specs_llm_context_enrichment_design", "target": "main_failure_category_concept", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-05-31-llm-context-